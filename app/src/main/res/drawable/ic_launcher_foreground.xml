                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Checker Piece Body -->
    <path android:pathData="M 26,54 L 26,66 A 28,14 0 0,0 82,66 L 82,54 A 28,14 0 0,1 26,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="26" android:startY="54" android:endX="82" android:endY="54">
                <item android:offset="0.0" android:color="#B8860B" />
                <item android:offset="0.3" android:color="#FFD700" />
                <item android:offset="0.7" android:color="#FFD700" />
                <item android:offset="1.0" android:color="#8B6508" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Grooves on side -->
    <path android:pathData="M 26,58 A 28,14 0 0,0 82,58 L 82,60 A 28,14 0 0,1 26,60 Z" android:fillColor="#66330000"/>
    <path android:pathData="M 26,62 A 28,14 0 0,0 82,62 L 82,64 A 28,14 0 0,1 26,64 Z" android:fillColor="#66330000"/>

    <!-- Checker Piece Top -->
    <path android:pathData="M 26,54 A 28,14 0 1,0 82,54 A 28,14 0 1,0 26,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="26" android:startY="40" android:endX="82" android:endY="68">
                <item android:offset="0.0" android:color="#FFF59D" />
                <item android:offset="0.4" android:color="#FFD700" />
                <item android:offset="1.0" android:color="#DAA520" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner Ring 1 -->
    <path android:pathData="M 32,54 A 22,11 0 1,0 76,54 A 22,11 0 1,0 32,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="32" android:startY="65" android:endX="76" android:endY="43">
                <item android:offset="0.0" android:color="#DAA520" />
                <item android:offset="0.6" android:color="#FFD700" />
                <item android:offset="1.0" android:color="#FFF59D" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner Ring 2 -->
    <path android:pathData="M 38,54 A 16,8 0 1,0 70,54 A 16,8 0 1,0 38,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="38" android:startY="46" android:endX="70" android:endY="62">
