    <path android:pathData="M 52,41 L 54,41 L 49,52 L 48,52 Z" android:fillColor="#CCFFFFFF"/>
    <path android:pathData="M 64,48 L 66,46 L 64,56 L 63,56 Z" android:fillColor="#80FFFFFF"/>
    
    <!-- Crown Jewels -->
    <!-- Center top -->
    <path android:pathData="M 52,38 A 2,2 0 1,0 56,38 A 2,2 0 1,0 52,38 Z" android:fillColor="#FF1744"/>
    <!-- Left top -->
    <path android:pathData="M 38,44 A 2,2 0 1,0 42,44 A 2,2 0 1,0 38,44 Z" android:fillColor="#00E5FF"/>
    <!-- Right top -->
    <path android:pathData="M 66,44 A 2,2 0 1,0 70,44 A 2,2 0 1,0 66,44 Z" android:fillColor="#00E5FF"/>
    
    <!-- Base Jewels -->
    <path android:pathData="M 46,56.2 A 0.8,0.8 0 1,0 47.6,56.2 A 0.8,0.8 0 1,0 46,56.2 Z" android:fillColor="#FFFFFF"/>
    <path android:pathData="M 50,56.2 A 1,1 0 1,0 52,56.2 A 1,1 0 1,0 50,56.2 Z" android:fillColor="#00E5FF"/>
    <path android:pathData="M 54,56.2 A 1,1 0 1,0 56,56.2 A 1,1 0 1,0 54,56.2 Z" android:fillColor="#FF1744"/>
    <path android:pathData="M 58,56.2 A 1,1 0 1,0 60,56.2 A 1,1 0 1,0 58,56.2 Z" android:fillColor="#00E5FF"/>
    <path android:pathData="M 62.4,56.2 A 0.8,0.8 0 1,0 64,56.2 A 0.8,0.8 0 1,0 62.4,56.2 Z" android:fillColor="#FFFFFF"/>

    <!-- Additional Ambient Lighting overlay for extreme glossy 3D effect -->
    <path android:pathData="M 26,54 L 26,66 A 28,14 0 0,0 82,66 L 82,54 A 28,14 0 0,1 26,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="26" android:startY="54" android:endX="40" android:endY="54">
                <item android:offset="0.0" android:color="#40FFFFFF" />
                <item android:offset="1.0" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>
    <path android:pathData="M 26,54 A 28,14 0 1,0 82,54 A 28,14 0 1,0 26,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial" android:centerX="36" android:centerY="50" android:gradientRadius="18">
                <item android:offset="0.0" android:color="#60FFFFFF" />
                <item android:offset="1.0" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
