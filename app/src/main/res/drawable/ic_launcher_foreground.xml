    <path android:pathData="M 44,56 L 42,46 L 48,52 L 54,41 L 60,52 L 66,46 L 64,56 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="42" android:startY="41" android:endX="66" android:endY="56">
